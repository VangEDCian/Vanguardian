Project Vanguardian {
  database_type: "MariaDB"
  Note: "DB-first logical schema for EDC modular monolith. Includes project-owned structures for identity, study, CRF, data capture, reconcile, governance, audit, exporting, and dashboard-read. Django framework tables (auth/contenttypes/session/admin/migrations and auto M2M tables) are intentionally omitted to reduce diagram noise."
}

Table identity_user {
  id bigint [pk, increment]
  password varchar(128) [not null]
  last_login datetime
  is_superuser tinyint [not null, default: 0]
  username varchar(150) [not null, unique]
  first_name varchar(150) [not null, default: '']
  last_name varchar(150) [not null, default: '']
  email varchar(254) [not null, default: '']
  is_staff tinyint [not null, default: 0]
  is_active tinyint [not null, default: 1]
  date_joined datetime [not null]

  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  display_name varchar(255) [not null, default: '']
  time_zone varchar(64) [not null, default: 'Asia/Ho_Chi_Minh']
  attemp_login smallint [not null, default: 0]
  date_leaved datetime

  created_by_id bigint
  updated_by_id bigint

  Note: "Custom user model extending Django auth semantics with operational profile metadata. Django-managed M2M tables for user-group and user-permission are intentionally omitted."
}

Table identity_role {
  id bigint [pk, increment]
  name varchar(150) [not null, unique]
  description varchar(255) [not null, default: '']

  Note: "Business role layer: one role can aggregate many groups and many direct permissions."
}

Table identity_role_groups {
  id bigint [pk, increment]
  role_id bigint [not null]
  group_id int [not null]

  indexes {
    (role_id, group_id) [unique, name: "identity_role_groups_role_group_uniq"]
  }

  Note: "group_id points to Django-managed auth_group table (omitted from this diagram)."
}

Table identity_role_permissions {
  id bigint [pk, increment]
  role_id bigint [not null]
  permission_id int [not null]

  indexes {
    (role_id, permission_id) [unique, name: "identity_role_permissions_role_permission_uniq"]
  }

  Note: "permission_id points to Django-managed auth_permission table (omitted from this diagram)."
}

Table study_study {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  code varchar(64) [not null, unique]
  name varchar(255) [not null]
  sponsor varchar(255) [not null]
  start_date date
  end_date date
  description longtext [not null]
  is_active tinyint [not null, default: 1]

  created_by_id bigint
  updated_by_id bigint

  Note: "Study master. Protocol-level policies (including randomization and status transition constraints) are applied from this context."
}

Table study_site {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  code varchar(64) [not null]
  name varchar(255) [not null]
  investigator varchar(255) [not null]
  is_active tinyint [not null, default: 1]

  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (study_id, code) [unique, name: "study_site_study_code_uniq"]
  }
}

Table study_subject {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  subject_code varchar(64) [not null]
  status varchar(32) [not null, note: "Allowed business statuses: Screened, Enrolled, Randomized, ScreenFailure, Completed, Withdrawn, Discontinued"]
  status_datetime datetime
  subject_status_reason_code varchar(64)
  subject_status_reason_text longtext

  enrollment_date date

  randomization_status varchar(16)
  randomization_datetime datetime
  randomization_sequence varchar(64)
  randomization_number varchar(64)
  randomization_source varchar(16) [note: "manual/system/iwrs/irt/import"]
  randomized_by_id bigint

  site_id bigint [not null]
  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (study_id, site_id, subject_code) [unique, name: "study_subject_study_site_subject_code_uniq"]
    (study_id, status) [name: "study_subject_study_status_idx"]
    (study_id, randomization_number) [name: "study_subject_study_randomization_number_idx"]
  }

  Note: "Canonical subject lifecycle state in study context. Randomization metadata is mandatory by policy when status=Randomized."
}

Table study_subject_status_history {
  id bigint [pk, increment]
  subject_id bigint [not null]
  from_status varchar(32)
  to_status varchar(32) [not null]
  transition_at datetime [not null]
  reason_code varchar(64)
  reason_text longtext
  source varchar(16) [not null, default: 'system', note: "manual/system/iwrs/irt/import"]
  changed_by_id bigint

  indexes {
    (subject_id, transition_at) [name: "study_subject_status_history_subject_time_idx"]
  }

  Note: "Immutable lifecycle transition log for subject status (required for auditability and governance)."
}

Table study_subject_period {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  period_no smallint [not null]
  treatment_code varchar(64) [not null]
  planned_dose_datetime datetime
  actual_dose_datetime datetime
  washout_start_datetime datetime
  washout_end_datetime datetime
  status varchar(16) [not null, default: 'Planned']

  subject_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (subject_id, period_no) [unique, name: "study_subject_period_subject_period_uniq"]
    (subject_id, treatment_code) [name: "study_subject_period_subject_treatment_idx"]
  }

  Note: "Crossover period execution per subject: planned/actual dosing and washout markers."
}

Table study_randomization_event {
  id bigint [pk, increment]
  created_at datetime [not null]

  event_type varchar(32) [not null, note: "Pending/Assigned/Confirmed/Failed/Cancelled/Reassigned/Reversed"]
  randomization_status varchar(16)
  randomization_datetime datetime
  randomization_sequence varchar(64)
  randomization_number varchar(64)
  randomization_source varchar(16) [not null, note: "manual/system/iwrs/irt/import"]
  reason_code varchar(64)
  reason_text longtext
  before_data longtext
  after_data longtext

  subject_id bigint [not null]
  study_id bigint [not null]
  actor_id bigint
  created_by_id bigint

  indexes {
    (subject_id, created_at) [name: "study_randomization_event_subject_time_idx"]
    (study_id, randomization_number, created_at) [name: "study_randomization_event_study_number_time_idx"]
  }

  Note: "Immutable event log for every randomization metadata change."
}

Table study_status_transition_policy {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  from_status varchar(32) [note: "NULL means initial transition."]
  to_status varchar(32) [not null]
  requires_reason tinyint [not null, default: 0]
  is_terminal tinyint [not null, default: 0]
  allow_reopen tinyint [not null, default: 0]
  reopen_rule longtext
  is_active tinyint [not null, default: 1]

  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (study_id, from_status, to_status) [unique, name: "study_status_transition_policy_transition_uniq"]
    (study_id, is_active) [name: "study_status_transition_policy_study_active_idx"]
  }

  Note: "Study-specific transition policy to enforce allowed lifecycle flow and terminal/reopen controls."
}

Table study_visittemplate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  code varchar(64) [not null]
  name varchar(255) [not null]
  visit_order int [not null]
  window_min_days int
  window_max_days int
  description longtext [not null]
  is_mandatory tinyint [not null, default: 1]

  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (study_id, code) [unique, name: "study_visittemplate_study_code_uniq"]
  }
}

Table study_visit {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  name varchar(255) [not null]
  visit_date date
  status varchar(32) [not null]

  subject_id bigint [not null]
  visit_template_id bigint
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (subject_id, visit_template_id) [name: "study_visit_subject_visittemplate_idx"]
  }
}

Table crf_crftemplate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  code varchar(64) [not null]
  name varchar(255) [not null]
  version varchar(32) [not null]
  is_active tinyint [not null, default: 1]

  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (study_id, code, version) [unique, name: "crf_crftemplate_study_code_version_uniq"]
  }
}

Table crf_pagetemplate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  code varchar(64) [not null]
  title varchar(255) [not null]
  order int [not null]

  crf_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (crf_template_id, code) [unique, name: "crf_pagetemplate_crf_template_code_uniq"]
  }
}

Table study_visittemplate_crftemplate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  is_required tinyint [not null, default: 1]
  max_repeat int [not null, default: 1]
  order int [not null, default: 1]

  visit_template_id bigint [not null]
  crf_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (visit_template_id, crf_template_id) [unique, name: "study_visittemplate_crftemplate_visit_crf_uniq"]
  }
}

Table crf_fieldtemplate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  field_key varchar(100) [not null]
  label longtext [not null]
  data_type varchar(20) [not null]
  is_active tinyint [not null, default: 1]

  page_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (page_template_id, field_key) [unique, name: "crf_fieldtemplate_page_fieldkey_uniq"]
  }
}

Table crf_fielddefinition {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  sdtm longtext
  unit varchar(50)
  range_min decimal(21,6)
  range_max decimal(21,6)
  precision int
  allowed_missing_values longtext [not null]
  codelist longtext [not null]
  data_semantic longtext
  comments longtext
  text_max_length int
  text_min_length int
  pattern longtext
  pattern_err_msg longtext

  field_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    field_template_id [unique, name: "crf_fielddefinition_field_template_uniq"]
  }
}

Table crf_fielduiconfig {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  control_type varchar(50) [not null]
  layout longtext
  text longtext
  behavior longtext
  options longtext
  style longtext

  field_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    field_template_id [unique, name: "crf_fielduiconfig_field_template_uniq"]
  }
}

Table crf_fieldvalidationrule {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  rule_type varchar(64) [not null]
  expression longtext [not null]
  message longtext [not null]
  severity varchar(20) [not null]
  mode varchar(20) [not null]

  field_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint
}

Table datacapture_pagestate {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  status varchar(16) [not null]
  final_data longtext [not null]
  verified_at datetime
  locked_at datetime

  page_template_id bigint [not null]
  subject_id bigint [not null]
  visit_id bigint [not null]

  created_by_id bigint
  updated_by_id bigint
  verified_by_id bigint
  locked_by_id bigint

  indexes {
    (subject_id, visit_id, page_template_id) [unique, name: "datacapture_pagestate_subject_visit_page_uniq"]
  }
}

Table datacapture_pageentry {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  entry_version varchar(16) [not null]
  data longtext [not null]
  status varchar(16) [not null]

  page_template_id bigint [not null]
  subject_id bigint [not null]
  visit_id bigint [not null]

  created_by_id bigint
  updated_by_id bigint

  indexes {
    (subject_id, visit_id, page_template_id, entry_version) [name: "datacapture_pageentry_subject_visit_page_version_idx"]
  }
}

Table reconcile_dataquery {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  status varchar(16) [not null]
  source varchar(16) [not null]
  question_text longtext [not null]
  resolution_note varchar(255)
  closed_at datetime

  page_state_id bigint [not null]
  field_template_id bigint
  validation_rule_id bigint
  assigned_to_id bigint
  created_by_id bigint
  updated_by_id bigint

  Note: "Reconcile-owned query aggregate. Datacapture provides context via page_state_id/field_template_id/validation_rule_id references."
}

Table reconcile_query_thread {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  message_text longtext [not null]
  message_type varchar(16) [not null, default: 'comment', note: "comment/status_change/resolution"]
  visibility varchar(16) [not null, default: 'site', note: "site/sponsor/internal"]
  source varchar(16) [not null, default: 'manual', note: "manual/system/import"]

  dataquery_id bigint [not null]
  author_id bigint
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (dataquery_id, created_at) [name: "reconcile_query_thread_query_time_idx"]
  }

  Note: "Threaded communication log for data query handling, owned by reconcile workflow."
}

Table reconcile_reconcilerecord {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  entry01_value varchar(512) [not null]
  entry02_value varchar(512) [not null]
  final_value varchar(512) [not null]
  status varchar(16) [not null]
  reason varchar(255) [not null]

  page_state_id bigint [not null]
  field_template_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (page_state_id, field_template_id) [unique, name: "reconcile_reconcilerecord_pagestate_field_uniq"]
  }
}

Table governance_databaselock {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  is_locked tinyint [not null, default: 0]
  lock_reason longtext [not null]
  locked_at datetime
  unlock_reason longtext [not null]
  unlocked_at datetime

  study_id bigint [not null]
  created_by_id bigint
  updated_by_id bigint
  locked_by_id bigint
  unlocked_by_id bigint

  indexes {
    study_id [unique, name: "governance_databaselock_study_uniq"]
  }
}

Table governance_lockrecord {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  level varchar(16) [not null]
  reason longtext [not null]
  locked_at datetime [not null]
  unlocked_at datetime

  page_state_id bigint
  created_by_id bigint
  updated_by_id bigint
  locked_by_id bigint
  unlocked_by_id bigint
}

Table audit_auditevent {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  action varchar(64) [not null]
  object_type varchar(64) [not null]
  object_id varchar(64) [not null]
  before_data longtext [not null]
  after_data longtext [not null]
  ip_address char(39)
  user_agent varchar(255) [not null]

  user_id bigint
  created_by_id bigint
  updated_by_id bigint

  indexes {
    (object_type, object_id, created_at) [name: "audit_auditevent_object_timeline_idx"]
  }

  Note: "Immutable audit events for compliance and traceability."
}

Table exporting_exportjob {
  id bigint [pk, increment]
  created_at datetime [not null]
  updated_at datetime [not null]
  deleted tinyint [not null, default: 0]

  format varchar(8) [not null]
  status varchar(16) [not null]
  filters longtext [not null]
  file_path varchar(512) [not null]
  error_message longtext [not null]

  study_id bigint [not null]
  requested_by_id bigint
  created_by_id bigint
  updated_by_id bigint
}

