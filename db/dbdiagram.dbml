Project Vanguardian {
  database_type: "MariaDB"
  Note: "Identity foundation follows django-auth semantics with a custom user table. Permission records are created by Django migrate from django_content_type + model Meta.permissions. Role is a project-level access bundle that can aggregate both permissions and groups."
}

Table django_content_type {
  id int [pk, increment]
  app_label varchar(100) [not null]
  model varchar(100) [not null]

  Note: "Django core content type registry."

  indexes {
    (app_label, model) [unique]
  }
}

Table auth_permission {
  id int [pk, increment]
  name varchar(255) [not null]
  content_type_id int [not null]
  codename varchar(100) [not null]

  Note: "Permission records exist in the standard django-auth table and are generated by Django migrate."

  indexes {
    (content_type_id, codename) [unique]
  }
}

Table auth_group {
  id int [pk, increment]
  name varchar(150) [not null, unique]

  Note: "Group is treated as a permission bundle in Django auth and can be assigned to users and roles."
}

Table auth_group_permissions {
  id bigint [pk, increment]
  group_id int [not null]
  permission_id int [not null]

  indexes {
    (group_id, permission_id) [unique]
  }
}

Table identity_user {
  id bigint [pk, increment]
  username varchar(150) [not null, unique]
  password varchar(128) [not null]
  first_name varchar(150)
  last_name varchar(150)
  email varchar(254)
  is_staff boolean [not null, default: false]
  is_active boolean [not null, default: true]
  is_superuser boolean [not null, default: false]
  last_login timestamp
  date_joined timestamp [not null]

  Note: "Custom user model based on django.contrib.auth.models.AbstractUser. No default Django model permissions are auto-created for this model."
}

Table identity_user_groups {
  id bigint [pk, increment]
  user_id bigint [not null]
  group_id int [not null]

  indexes {
    (user_id, group_id) [unique]
  }
}

Table identity_user_user_permissions {
  id bigint [pk, increment]
  user_id bigint [not null]
  permission_id int [not null]

  indexes {
    (user_id, permission_id) [unique]
  }
}

Table identity_role {
  id bigint [pk, increment]
  name varchar(150) [not null, unique]
  description varchar(255) [not null, default: '']

  Note: "Role is a project-defined access bundle. One role can combine many groups and many permissions."
}

Table identity_role_groups {
  id bigint [pk, increment]
  role_id bigint [not null]
  group_id int [not null]

  indexes {
    (role_id, group_id) [unique]
  }
}

Table identity_role_permissions {
  id bigint [pk, increment]
  role_id bigint [not null]
  permission_id int [not null]

  indexes {
    (role_id, permission_id) [unique]
  }
}

Ref: auth_permission.content_type_id > django_content_type.id
Ref: auth_group_permissions.group_id > auth_group.id
Ref: auth_group_permissions.permission_id > auth_permission.id
Ref: identity_user_groups.user_id > identity_user.id
Ref: identity_user_groups.group_id > auth_group.id
Ref: identity_user_user_permissions.user_id > identity_user.id
Ref: identity_user_user_permissions.permission_id > auth_permission.id
Ref: identity_role_groups.role_id > identity_role.id
Ref: identity_role_groups.group_id > auth_group.id
Ref: identity_role_permissions.role_id > identity_role.id
Ref: identity_role_permissions.permission_id > auth_permission.id
