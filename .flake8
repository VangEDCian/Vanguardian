[flake8]
select =
    DDD
    DJG
exclude =
    build,
    build/lib
per-file-ignores =
    src/apps/crf/infrastructure/repositories/form_builder.py: DDD001
    src/apps/crf/presentation/web/views/builder.py: DDD001
    src/apps/crf/presentation/web/views/builder_support.py: DDD001
    src/apps/crf/presentation/web/views/detail.py: DDD001
    src/apps/crf/presentation/web/views/field_update.py: DDD001
    src/apps/crf/public.py: DDD001
    src/apps/identity/infrastructure/auth/password_validation.py: DDD001
    src/apps/identity/presentation/web/forms.py: DDD001
    src/apps/identity/presentation/web/views/auth.py: DDD001
    src/apps/identity/presentation/web/views/users.py: DDD001
    src/apps/study/presentation/web/forms/eventdefinitions.py: DDD001
    src/apps/study/presentation/web/forms/site.py: DDD001
    src/apps/study/presentation/web/tables.py: DDD001
    src/apps/study/presentation/web/views/crf_templates.py: DDD001
    src/apps/study/presentation/web/views/eventdefinitions.py: DDD001
    src/apps/study/presentation/web/views/randomization.py: DDD001
    src/apps/study/presentation/web/views/site.py: DDD001
    src/apps/study/presentation/web/views/studies.py: DDD001
    src/apps/study/presentation/web/views/study_actions.py: DDD001
    src/apps/subject/infrastructure/repositories/event_lifecycle.py: DDD001
    src/apps/subject/presentation/web/forms.py: DDD001
    src/apps/subject/presentation/web/views/detail.py: DDD001
    src/apps/subject/presentation/web/views/detail_navigation.py: DDD001
    src/apps/subject/presentation/web/views/event_instance_files.py: DDD001
    src/apps/subject/presentation/web/views/verification_verify_checked.py: DDD001
    src/apps/subject/public.py: DDD001

[flake8:local-plugins]
extension =
    DDD = flake8_ddd:DDDChecker
    DJG = flake8_django:DjangoChecker
paths =
    ./tools
