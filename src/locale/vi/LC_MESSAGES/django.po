msgstr "Sử dụng tài khoản của bạn để tiếp tục vào hệ thống."

msgid "Sign in failed."
msgstr "Đăng nhập thất bại."

msgid "Username"
msgstr "Tên đăng nhập"

msgid "Password"
msgstr "Mật khẩu"

msgid "Show or hide password"
