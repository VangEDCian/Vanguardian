msgstr "Quên mật khẩu?"

#. ==============================
#. Module: Identity
#. Template: templates/identity/forgot_password.html
#. ==============================
msgid "Forgot Password | Vanguardian"
msgstr "Quên mật khẩu | Vanguardian"

msgid "Forgot Password"
msgstr "Quên mật khẩu"

msgid "Enter your email to receive password reset instructions."
msgstr "Nhập email để nhận hướng dẫn đặt lại mật khẩu."

msgid "Email Address"
msgstr "Địa chỉ email"

msgid "Submit Request"
msgstr "Gửi yêu cầu"

msgid "Back to Sign In"
msgstr "Quay lại đăng nhập"

#. ==============================
#. Module: Identity
#. Template: templates/identity/forgot_password_done.html
#. ==============================
msgid "Check Your Email | Vanguardian"
msgstr "Kiểm tra email | Vanguardian"

msgid "Check your email"
msgstr "Kiểm tra email của bạn"

msgid "If the account exists, we have sent password reset instructions."
msgstr "Nếu tài khoản tồn tại, chúng tôi đã gửi hướng dẫn đặt lại mật khẩu."

msgid "Please check your inbox and spam folder. The reset link will expire according to system security policy."
msgstr "Hãy kiểm tra hộp thư đến và thư mục spam. Liên kết đặt lại mật khẩu sẽ hết hạn theo chính sách bảo mật của hệ thống."

msgid "Next Steps"
msgstr "Tiếp theo"

msgid "Open the email containing the reset password link."
msgstr "Mở email chứa liên kết đặt lại mật khẩu."

msgid "Click the link and enter your new password."
msgstr "Nhấp liên kết và nhập mật khẩu mới."

msgid "If you have not received the email, try sending again after a few minutes."
msgstr "Nếu chưa nhận được email, thử gửi lại sau vài phút."

#. ==============================
#. Module: Identity
#. Template: templates/identity/reset_password.html
#. ==============================
msgid "Reset Password | Vanguardian"
msgstr "Đặt lại mật khẩu | Vanguardian"

msgid "Reset Password"
msgstr "Đặt lại mật khẩu"

msgid "Enter a new password for your account."
msgstr "Nhập mật khẩu mới cho tài khoản của bạn."

msgid "Weak"
msgstr "Yếu"

msgid "Medium"
msgstr "Trung bình"

msgid "Strong"
msgstr "Mạnh"

msgid "Passwords match"
msgstr "Mật khẩu khớp"

msgid "Passwords do not match"
msgstr "Mật khẩu không khớp"

msgid "New Password"
msgstr "Mật khẩu mới"

msgid "Password strength"
msgstr "Độ mạnh mật khẩu"

msgid "Confirm Password"
msgstr "Xác nhận mật khẩu"

msgid "Password Requirements"
msgstr "Yêu cầu mật khẩu"

msgid "The link is invalid or has expired."
msgstr "Liên kết không hợp lệ hoặc đã hết hạn."

msgid "Please create a new forgot password request to receive a new link."
msgstr "Hãy tạo lại yêu cầu quên mật khẩu để nhận liên kết mới."

msgid "Create New Request"
msgstr "Tạo lại yêu cầu"

#. ==============================
#. Module: Identity
#. Template: templates/identity/reset_password_done.html
#. ==============================
msgid "Password Updated | Vanguardian"
msgstr "Mật khẩu đã được cập nhật | Vanguardian"

msgid "Password Reset Successful"
msgstr "Đặt lại mật khẩu thành công"

msgid "You can sign in now with your new password."
msgstr "Bạn có thể đăng nhập bằng mật khẩu mới ngay bây giờ."

msgid "Your password has been saved successfully. Please continue with a new sign-in session."
msgstr "Mật khẩu của bạn đã được lưu thành công. Hãy tiếp tục với phiên đăng nhập mới."

#. ==============================
#. Module: Identity
#. Template: templates/identity/password_reset_email.txt
#. ==============================
msgid "You received this email because a password reset was requested for your Vanguardian account."
msgstr "Bạn nhận được email này vì đã yêu cầu đặt lại mật khẩu cho tài khoản Vanguardian."

msgid "Open the following link to reset your password:"
msgstr "Hãy mở liên kết sau để đặt lại mật khẩu:"

msgid "If you did not make this request, please ignore this email."
msgstr "Nếu bạn không thực hiện yêu cầu này, hãy bỏ qua email."

#. ==============================
#. Module: Identity
#. Template: templates/identity/password_reset_subject.txt
#. ==============================
msgid "Vanguardian - Password Reset Instructions"
msgstr "Vanguardian - Hướng dẫn đặt lại mật khẩu"
